{
  "openapi": "3.0.1",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api/v1",
      "description": "Generated server url"
    }
  ],
  "paths": {
    "/stocks/price": {
      "post": {
        "tags": ["stock-price-controller"],
        "operationId": "getStockPrice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StockPriceRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StockPriceResponse" }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegistrationRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/auth/authenticate": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "authenticate",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthenticationRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthenticationResponse" }
              }
            }
          }
        }
      }
    },
    "/alerts": {
      "get": {
        "tags": ["alerts-controller"],
        "operationId": "getUserAlerts",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AlertsResponse" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["alerts-controller"],
        "operationId": "createAlert",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AlertsRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AlertsResponse" }
              }
            }
          }
        }
      }
    },
    "/alerts/{id}/toggle": {
      "patch": {
        "tags": ["alerts-controller"],
        "operationId": "toggleAlert",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AlertsResponse" }
              }
            }
          }
        }
      }
    },
    "/alerts/{id}": {
      "delete": {
        "tags": ["alerts-controller"],
        "operationId": "deleteAlert",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/auth/activate-account": {
      "get": {
        "tags": ["Authentication"],
        "operationId": "confirm",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StockPriceRequest": {
        "type": "object",
        "properties": {
          "ticker": { "type": "string" }
        }
      },
      "StockPriceResponse": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "exchange": { "type": "string" },
          "price": { "type": "string" },
          "datetime": { "type": "string" }
        }
      },
      "RegistrationRequest": {
        "required": ["email", "firstname", "lastname", "password"],
        "type": "object",
        "properties": {
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "email": { "type": "string" },
          "password": { "maxLength": 2147483647, "minLength": 8, "type": "string" }
        }
      },
      "AuthenticationRequest": {
        "required": ["email", "password"],
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "maxLength": 2147483647, "minLength": 8, "type": "string" }
        }
      },
      "AuthenticationResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" }
        }
      },
      "AlertsRequest": {
        "required": ["alertType", "notificationChannel", "threshold", "ticker"],
        "type": "object",
        "properties": {
          "ticker": { "type": "string" },
          "alertType": { "type": "string", "enum": ["DIP", "RISE"] },
          "threshold": { "type": "number", "format": "double" },
          "notificationChannel": { "type": "string", "enum": ["EMAIL", "WHATSAPP", "BOTH"] }
        }
      },
      "AlertsResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "ticker": { "type": "string" },
          "alertType": { "type": "string", "enum": ["DIP", "RISE"] },
          "threshold": { "type": "number", "format": "double" },
          "notificationChannel": { "type": "string", "enum": ["EMAIL", "WHATSAPP", "BOTH"] },
          "active": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}